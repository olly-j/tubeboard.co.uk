# Web service
PORT=4173
SITE_DIR=03-Website

# Live Activity worker
LIVE_ACTIVITY_WORKER_ENABLED=true
LIVE_ACTIVITY_WORKER_INTERVAL_MS=60000
LIVE_ACTIVITY_DATA_FILE=data/live-activities.json
LIVE_ACTIVITY_MAX_ACTIVE_HOURS=8
LIVE_ACTIVITY_RETENTION_HOURS=24

# TfL Open Data. Optional, but recommended for production rate limits.
TFL_APP_KEY=

# APNs Live Activity push auth.
# Use either APNS_AUTH_KEY_PATH or APNS_AUTH_KEY.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_AUTH_KEY_PATH=
APNS_AUTH_KEY=
APNS_BUNDLE_ID=OllyJ.My-Train-Times
